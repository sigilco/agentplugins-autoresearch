{
  "name": "agentplugins-autoresearch",
  "version": "0.1.0",
  "type": "module",
  "description": "Autonomous experiment loop for agentplugins — run, measure, keep or discard. Agentplugins port of pi-autoresearch.",
  "keywords": [
    "agentplugins",
    "autoresearch",
    "experiment",
    "optimization",
    "benchmark",
    "mcp"
  ],
  "license": "MIT",
  "author": "David Cortés <477473+davebcn87@users.noreply.github.com>",
  "homepage": "https://github.com/davebcn87/agentplugins-autoresearch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davebcn87/agentplugins-autoresearch.git"
  },
  "bugs": {
    "url": "https://github.com/davebcn87/agentplugins-autoresearch/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "files": [
    "dist",
    "src",
    "skills",
    "assets",
    "agentplugins.config.ts",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
